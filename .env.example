# Variables d'environnement requises — copier ce fichier en .env et remplir les valeurs
# NE PAS commiter le fichier .env

# Base de données PostgreSQL
DB_USERNAME=postgre
DB_PASSWORD=changeme
DB_NAME=event

# Keycloak
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=changeme
KC_HOSTNAME=localhost

# Spring Boot (optionnel, valeurs par défaut fournies)
SERVER_PORT=8090
SPRING_PROFILES_ACTIVE=dev
