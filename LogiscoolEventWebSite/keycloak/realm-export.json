{
  "realm": "logiscool",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "logiscool-angular",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:4200/*",
        "http://localhost/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://localhost"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:4200/*##http://localhost/*##http://localhost"
      }
    }
  ],
  "defaultRoles": ["USER"],
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Standard user role"
      },
      {
        "name": "ADMIN",
        "description": "Administrator role"
      }
    ]
  },
  "users": [
    {
      "username": "user1",
      "enabled": true,
      "emailVerified": true,
      "email": "user1@logiscool.com",
      "firstName": "User",
      "lastName": "One",
      "credentials": [
        {
          "type": "password",
          "value": "user1pass",
          "temporary": false
        }
      ],
      "realmRoles": ["USER"]
    },
    {
      "username": "admin1",
      "enabled": true,
      "emailVerified": true,
      "email": "admin1@logiscool.com",
      "firstName": "Admin",
      "lastName": "One",
      "credentials": [
        {
          "type": "password",
          "value": "admin1pass",
          "temporary": false
        }
      ],
      "realmRoles": ["USER", "ADMIN"]
    }
  ]
}
