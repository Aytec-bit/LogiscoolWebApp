# ============================================================
#  LogiscoolWebApp — Variables d'environnement
#  Copier ce fichier en .env avant de lancer docker compose :
#    Windows : copy .env.example .env
#    macOS/Linux : cp .env.example .env
#
#  Le fichier .env N'EST PAS commité (voir .gitignore).
#  Ces valeurs sont des valeurs par défaut pour le développement local.
#  NE PAS utiliser ces valeurs en production.
# ============================================================

# --- Base de données PostgreSQL ---
DB_USERNAME=postgre
DB_PASSWORD=logiscool_dev
DB_NAME=event

# --- Keycloak ---
# Compte admin de l'interface d'administration Keycloak (http://localhost:8180)
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin
# Hostname Keycloak (localhost pour dev local, domaine public en prod)
KC_HOSTNAME=localhost
